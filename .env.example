PORT=3000
CORS_ORIGIN=*
DATABASE_PATH=./data/careeros.sqlite

# Optional: when set, requests must include either:
# Authorization: Bearer <APP_API_SECRET>
# X-Demo-Secret: <APP_API_SECRET>
APP_API_SECRET=

# Live job search. Prefer SerpApi Google Jobs when available.
SERPAPI_API_KEY=

# Optional Bright Data search/web-unlocker adapter endpoint.
BRIGHTDATA_SEARCH_URL=
BRIGHTDATA_API_KEY=

# Resume and job-intelligence parsing.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
